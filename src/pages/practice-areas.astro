---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionWrapper from "../components/common/SectionWrapper.astro";
import CTABanner from "../components/sections/CTABanner.astro";
import Icon from "../components/common/Icon.astro";

interface PracticeArea {
    icon: string;
    title: string;
    description: string;
    services: string[];
}

const practiceAreas: PracticeArea[] = [
    {
        icon: "scale",
        title: "General Civil Litigation",
        description:
            "We represent clients across all levels of the Sabah courts in a wide range of civil disputes — from contract breaches and tortious claims to debt recovery and injunctive relief.",
        services: [
            "Contract disputes and breach of contract claims",
            "Negligence, defamation, and other tortious claims",
            "Debt recovery and enforcement of judgments",
            "Injunctions and other equitable remedies",
            "Appellate advocacy before the Court of Appeal and Federal Court",
        ],
    },
    {
        icon: "briefcase",
        title: "Company Law",
        description:
            "We advise and guide businesses on all aspects of corporate law — from initial incorporation and governance through to shareholder disputes and winding-up proceedings.",
        services: [
            "Company incorporation and registration",
            "Corporate governance, compliance, and advisory",
            "Shareholder disputes and derivative actions",
            "Joint ventures and business structuring",
            "Winding up and liquidation proceedings",
        ],
    },
    {
        icon: "home",
        title: "Conveyancing",
        description:
            "End-to-end property transaction services for residential, commercial, and industrial properties — ensuring every transfer is legally sound and professionally handled.",
        services: [
            "Sale and Purchase Agreements (SPA) for residential and commercial properties",
            "Memorandum of Transfer (MOT) preparation and execution",
            "Loan documentation, drawdown, and redemption",
            "Strata title applications and transfers",
            "Native land and leasehold dealings in Sabah",
        ],
    },
    {
        icon: "hard-hat",
        title: "Construction & Adjudication",
        description:
            "Specialised services for construction disputes — including adjudication under the Construction Industry Payment and Adjudication Act (CIPAA) and arbitration proceedings.",
        services: [
            "CIPAA adjudication proceedings",
            "Construction contract review and advisory",
            "Claims for unpaid progress payments",
            "Defect liability and project delay disputes",
            "Arbitration in construction and infrastructure matters",
        ],
    },
    {
        icon: "file-text",
        title: "Non-Contentious Matters",
        description:
            "Legal documentation, estate planning, and advisory services for individuals and families who need quality legal support without court proceedings.",
        services: [
            "Will drafting and testamentary advice",
            "Estate administration — Grant of Probate and Letters of Administration",
            "Deed of Partnership and business documentation",
            "Statutory declarations and affidavits",
            "General legal advisory and document preparation",
        ],
    },
    {
        icon: "shield",
        title: "Criminal Litigation",
        description:
            "Vigorous and principled criminal defence at all court levels — ensuring every client receives fair representation regardless of the complexity of the charges.",
        services: [
            "Criminal defence in Magistrates', Sessions', and High Court",
            "Bail applications and representations",
            "Appeal against conviction or sentence",
            "White-collar and financial crime defence",
            "Drug offences and traffic-related criminal matters",
        ],
    },
    {
        icon: "map-pin",
        title: "Land Dispute",
        description:
            "Resolution of land and property conflicts unique to Sabah — including Native Customary Rights (NCR) claims, title disputes, and boundary-related actions.",
        services: [
            "Boundary dispute resolution and demarcation",
            "Native Customary Rights (NCR) claims and advocacy",
            "Trespass and encroachment actions",
            "Land title registration issues and rectification",
            "Caveats and injunctions over land",
        ],
    },
];

const quickStats = [
    { icon: "scale", label: "7 Practice Areas" },
    { icon: "users", label: "Experienced Partners & Legal Assistants" },
    { icon: "map-pin", label: "Serving Kota Kinabalu & All of Sabah" },
    { icon: "shield", label: "Sabah Bar Admitted Practitioners" },
];
---

<BaseLayout
    title="Practice Areas — Jason Zulfadli Advocates & Solicitors"
    description="Explore our seven core practice areas — civil litigation, conveyancing, company law, criminal defence, construction adjudication, non-contentious matters, and land disputes. Serving Kota Kinabalu and Sabah."
>
    {/* 1. Page Hero */}
    <section
        class="bg-primary py-20 md:py-28 relative overflow-hidden"
        aria-label="Practice Areas page hero"
    >
        <div
            class="absolute top-0 right-0 w-80 h-80 bg-secondary/10 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"
            aria-hidden="true"
        ></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="flex items-center gap-2 mb-4">
                <a
                    href="/"
                    class="text-white/50 hover:text-white text-sm font-body transition-colors"
                    >Home</a
                >
                <Icon name="chevron-right" size="sm" class="text-white/30" />
                <span class="text-white/80 text-sm font-body">Practice Areas</span>
            </div>
            <span
                class="text-saffron text-sm font-semibold uppercase tracking-widest font-body block mb-4"
            >
                What We Do
            </span>
            <h1
                class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-white leading-tight max-w-3xl"
            >
                Our Practice Areas
            </h1>
            <p
                class="mt-6 text-lg font-body text-white/75 max-w-xl leading-relaxed"
            >
                We offer a comprehensive range of legal services for individuals,
                families, and businesses across Kota Kinabalu and Sabah —
                delivered with professionalism, fresh thinking, and genuine care.
            </p>
        </div>
    </section>

    {/* 2. Intro */}
    <SectionWrapper id="intro">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-16 items-start">
            {/* Left — narrative */}
            <div class="lg:col-span-2">
                <span
                    class="text-secondary text-sm font-semibold uppercase tracking-widest font-body block mb-3"
                >
                    Our Expertise
                </span>
                <h2
                    class="text-3xl md:text-4xl font-display font-semibold text-primary mb-6 leading-snug"
                >
                    Comprehensive Legal Services in Sabah
                </h2>
                <div
                    class="space-y-4 font-body text-gray-700 text-base leading-relaxed"
                >
                    <p>
                        <strong class="text-primary font-semibold"
                            >Jason Zulfadli Advocates &amp; Solicitors</strong
                        > handles seven core practice areas — covering both contentious
                        and non-contentious legal work for clients throughout Sabah.
                        Whether you are a first-time property buyer, a business owner
                        navigating a dispute, or an individual facing criminal proceedings,
                        our team brings focused expertise and genuine dedication to
                        your matter.
                    </p>
                    <p>
                        Our approach is collaborative. We begin every engagement
                        by understanding your specific situation, then develop a
                        clear and practical legal strategy tailored to your goals
                        — not just legal opinions, but actionable answers.
                    </p>
                </div>
            </div>

            {/* Right — quick stats */}
            <div class="flex flex-col gap-3">
                {
                    quickStats.map((stat) => (
                        <div class="flex items-center gap-3 bg-gray-50 rounded-lg border border-gray-200 px-4 py-3">
                            <div class="w-8 h-8 rounded-md bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <Icon name={stat.icon} size="sm" />
                            </div>
                            <span class="font-body text-sm font-medium text-gray-700">
                                {stat.label}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>
    </SectionWrapper>

    {/* 3. Detailed Practice Areas Grid */}
    <SectionWrapper id="areas" class="bg-gray-50">
        <div class="text-center max-w-2xl mx-auto mb-14">
            <span
                class="text-secondary text-sm font-semibold uppercase tracking-widest font-body block mb-3"
            >
                All Areas
            </span>
            <h2
                class="text-3xl md:text-4xl font-display font-semibold text-primary mb-4"
            >
                Explore Our Services
            </h2>
            <p class="text-gray-600 font-body text-base leading-relaxed">
                Each area is handled by our team with care, precision, and a
                commitment to delivering results that make a real difference.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                practiceAreas.map((area) => (
                    <div class="group bg-white rounded-lg border border-gray-200 shadow-sm p-6 flex flex-col gap-5 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
                        <div class="w-12 h-12 rounded-md bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300 shrink-0">
                            <Icon name={area.icon} size="lg" />
                        </div>
                        <div class="flex flex-col gap-3">
                            <h3 class="font-display font-semibold text-xl text-primary leading-snug">
                                {area.title}
                            </h3>
                            <p class="text-gray-600 font-body text-sm leading-relaxed">
                                {area.description}
                            </p>
                            <ul class="space-y-2 mt-1">
                                {area.services.map((service) => (
                                    <li class="flex items-start gap-2 text-sm text-gray-700 font-body">
                                        <Icon
                                            name="check"
                                            size="sm"
                                            class="text-secondary shrink-0 mt-0.5"
                                        />
                                        <span>{service}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                ))
            }
        </div>
    </SectionWrapper>

    {/* 4. CTA Banner */}
    <CTABanner
        heading="Not Sure Which Area Applies to You?"
        subCopy="Our team will listen to your situation and guide you to the right legal path. Reach out for a confidential consultation today."
        primaryLabel="Contact Us"
        primaryHref="/contact"
        secondaryLabel="Call the Office"
        secondaryHref="tel:088742076"
        phone="088-742076"
    />
</BaseLayout>
