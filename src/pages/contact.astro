---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionWrapper from "../components/common/SectionWrapper.astro";
import Button from "../components/common/Button.astro";
import Icon from "../components/common/Icon.astro";

// Replace with your actual Web3Forms access key or use: import.meta.env.WEB3FORMS_ACCESS_KEY
const accessKey = "90a583fc-a5b1-4f8b-bb4d-e4753028551e";

const contactDetails = [
    {
        icon: "map-pin",
        label: "Office Address",
        content:
            "Lot S6-3, 2nd Floor, Villa Tropicana Commercial,\nJalan Lintas, Penampang Bypass,\n88300 Kota Kinabalu, Sabah",
        isAddress: true,
    },
    {
        icon: "phone",
        label: "Phone",
        content: "088-742076",
        href: "tel:088742076",
    },
    {
        icon: "mail",
        label: "Email",
        content: "jzlegalfirm@gmail.com",
        href: "mailto:jzlegalfirm@gmail.com",
    },
    {
        icon: "clock",
        label: "Office Hours",
        content: "Monday – Friday\n9:00 am – 1:00 pm · 2:00 pm – 5:00 pm",
    },
];

const expectations = [
    "We respond to all enquiries within 1–2 business days.",
    "All consultations are treated with strict confidentiality.",
    "We will advise you on the most appropriate course of action for your matter.",
    "No obligation — initial enquiries are to understand your needs.",
];
---

<BaseLayout
    title="Contact Us — Jason Zulfadhli Advocates & Solicitors"
    description="Get in touch with Jason Zulfadhli Advocates & Solicitors in Kota Kinabalu, Sabah. Call us at 088-742076, email jzlegalfirm@gmail.com, or fill in our enquiry form for a confidential consultation."
>
    {/* 1. Page Hero */}
    <section
        class="bg-primary py-20 md:py-28 relative overflow-hidden"
        aria-label="Contact page hero"
    >
        <div
            class="absolute top-0 right-0 w-80 h-80 bg-secondary/10 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"
            aria-hidden="true"
        >
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="flex items-center gap-2 mb-4">
                <a
                    href="/"
                    class="text-white/50 hover:text-white text-sm font-body transition-colors"
                    >Home</a
                >
                <Icon name="chevron-right" size="sm" class="text-white/30" />
                <span class="text-white/80 text-sm font-body">Contact</span>
            </div>
            <span
                class="text-saffron text-sm font-semibold uppercase tracking-widest font-body block mb-4"
            >
                Get in Touch
            </span>
            <h1
                class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-white leading-tight max-w-3xl"
            >
                Contact Our Firm
            </h1>
            <p
                class="mt-6 text-lg font-body text-white/75 max-w-xl leading-relaxed"
            >
                Whether you need legal advice, representation, or simply want to
                find out how we can help — our team in Kota Kinabalu is ready to
                listen.
            </p>
        </div>
    </section>

    {/* 2. Contact Section — Form + Info */}
    <SectionWrapper id="contact">
        <div
            class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start"
        >
            {/* Left — Form (3 of 5 cols) */}
            <div class="lg:col-span-3">
                <span
                    class="text-secondary text-sm font-semibold uppercase tracking-widest font-body block mb-3"
                >
                    Send a Message
                </span>
                <h2
                    class="text-3xl md:text-4xl font-display font-semibold text-primary mb-8 leading-snug"
                >
                    Tell Us How We Can Help
                </h2>

                <form
                    id="contact-form"
                    action="https://api.web3forms.com/submit"
                    method="POST"
                    class="space-y-6"
                    novalidate
                >
                    <input type="hidden" name="access_key" value={accessKey} />
                    <input
                        type="checkbox"
                        name="botcheck"
                        class="hidden"
                        style="display:none;"
                    />

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="flex flex-col">
                            <label
                                for="name"
                                class="text-sm font-semibold text-gray-700 font-body mb-1.5"
                                >Full Name <span
                                    class="text-red-500"
                                    aria-hidden="true">*</span
                                ></label
                            >
                            <input
                                type="text"
                                id="name"
                                name="name"
                                required
                                autocomplete="name"
                                aria-required="true"
                                aria-describedby="name-error"
                                class="w-full rounded border border-gray-300 px-4 py-2.5 text-gray-900 font-body text-sm focus:border-secondary focus:ring-1 focus:ring-secondary aria-[invalid=true]:border-red-500 transition-colors"
                            />
                            <span
                                id="name-error"
                                class="text-red-500 text-xs mt-1.5 hidden font-body font-medium"
                                aria-live="polite"
                                >Please enter your full name.</span
                            >
                        </div>

                        <div class="flex flex-col">
                            <label
                                for="phone"
                                class="text-sm font-semibold text-gray-700 font-body mb-1.5"
                                >Phone Number <span
                                    class="text-red-500"
                                    aria-hidden="true">*</span
                                ></label
                            >
                            <input
                                type="tel"
                                id="phone"
                                name="phone"
                                required
                                autocomplete="tel"
                                aria-required="true"
                                aria-describedby="phone-error"
                                class="w-full rounded border border-gray-300 px-4 py-2.5 text-gray-900 font-body text-sm focus:border-secondary focus:ring-1 focus:ring-secondary aria-[invalid=true]:border-red-500 transition-colors"
                            />
                            <span
                                id="phone-error"
                                class="text-red-500 text-xs mt-1.5 hidden font-body font-medium"
                                aria-live="polite"
                                >Please enter a valid phone number.</span
                            >
                        </div>
                    </div>

                    <div class="flex flex-col">
                        <label
                            for="email"
                            class="text-sm font-semibold text-gray-700 font-body mb-1.5"
                            >Email Address <span
                                class="text-red-500"
                                aria-hidden="true">*</span
                            ></label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            autocomplete="email"
                            aria-required="true"
                            aria-describedby="email-error"
                            class="w-full rounded border border-gray-300 px-4 py-2.5 text-gray-900 font-body text-sm focus:border-secondary focus:ring-1 focus:ring-secondary aria-[invalid=true]:border-red-500 transition-colors"
                        />
                        <span
                            id="email-error"
                            class="text-red-500 text-xs mt-1.5 hidden font-body font-medium"
                            aria-live="polite"
                            >Please enter a valid email address.</span
                        >
                    </div>

                    <div class="flex flex-col">
                        <label
                            for="subject"
                            class="text-sm font-semibold text-gray-700 font-body mb-1.5"
                            >Practice Area / Subject <span
                                class="text-gray-400 font-normal"
                                >(Optional)</span
                            ></label
                        >
                        <select
                            id="subject"
                            name="subject"
                            class="w-full rounded border border-gray-300 px-4 py-2.5 text-gray-900 font-body text-sm focus:border-secondary focus:ring-1 focus:ring-secondary transition-colors bg-white"
                        >
                            <option value="">— Select a practice area —</option>
                            <option value="General Civil Litigation"
                                >General Civil Litigation</option
                            >
                            <option value="Company Law">Company Law</option>
                            <option value="Conveyancing">Conveyancing</option>
                            <option value="Construction & Adjudication"
                                >Construction &amp; Adjudication</option
                            >
                            <option value="Non-Contentious Matters"
                                >Non-Contentious Matters</option
                            >
                            <option value="Criminal Litigation"
                                >Criminal Litigation</option
                            >
                            <option value="Land Dispute">Land Dispute</option>
                            <option value="General Enquiry"
                                >General Enquiry</option
                            >
                        </select>
                    </div>

                    <div class="flex flex-col">
                        <label
                            for="message"
                            class="text-sm font-semibold text-gray-700 font-body mb-1.5"
                            >Message <span
                                class="text-red-500"
                                aria-hidden="true">*</span
                            ></label
                        >
                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            required
                            aria-required="true"
                            aria-describedby="message-error"
                            placeholder="Please briefly describe your legal matter or question..."
                            class="w-full rounded border border-gray-300 px-4 py-2.5 text-gray-900 font-body text-sm focus:border-secondary focus:ring-1 focus:ring-secondary aria-[invalid=true]:border-red-500 transition-colors resize-y"
                        ></textarea>
                        <span
                            id="message-error"
                            class="text-red-500 text-xs mt-1.5 hidden font-body font-medium"
                            aria-live="polite">Please enter your message.</span
                        >
                    </div>

                    <div class="pt-2">
                        <Button
                            type="submit"
                            class="w-full sm:w-auto px-8"
                            id="submit-btn"
                        >
                            <span id="btn-text">Send Message</span>
                            <svg
                                id="btn-spinner"
                                class="animate-spin ml-2 h-5 w-5 text-white hidden"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                aria-hidden="true"
                            >
                                <circle
                                    class="opacity-25"
                                    cx="12"
                                    cy="12"
                                    r="10"
                                    stroke="currentColor"
                                    stroke-width="4"></circle>
                                <path
                                    class="opacity-75"
                                    fill="currentColor"
                                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                                ></path>
                            </svg>
                        </Button>
                    </div>

                    {/* Status messages */}
                    <div
                        id="form-success"
                        class="hidden rounded-md bg-green-50 p-4 border border-green-200"
                        aria-live="polite"
                        role="status"
                    >
                        <div class="flex items-start gap-3">
                            <svg
                                class="h-5 w-5 text-green-500 shrink-0 mt-0.5"
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 20 20"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <div>
                                <p
                                    class="text-sm font-semibold text-green-800 font-body"
                                >
                                    Message sent successfully!
                                </p>
                                <p
                                    class="text-sm text-green-700 font-body mt-0.5"
                                >
                                    Thank you for reaching out. We will get back
                                    to you within 1–2 business days.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div
                        id="form-error"
                        class="hidden rounded-md bg-red-50 p-4 border border-red-200"
                        aria-live="polite"
                        role="alert"
                    >
                        <div class="flex items-start gap-3">
                            <svg
                                class="h-5 w-5 text-red-500 shrink-0 mt-0.5"
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 20 20"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <p
                                class="text-sm font-medium text-red-800 font-body"
                            >
                                Something went wrong. Please try again or call
                                us directly at <a
                                    href="tel:088742076"
                                    class="underline">088-742076</a
                                >.
                            </p>
                        </div>
                    </div>
                </form>
            </div>

            {/* Right — Contact Info (2 of 5 cols) */}
            <div class="lg:col-span-2 flex flex-col gap-6">
                <div>
                    <span
                        class="text-secondary text-sm font-semibold uppercase tracking-widest font-body block mb-3"
                    >
                        Reach Us Directly
                    </span>
                    <h2
                        class="text-2xl font-display font-semibold text-primary mb-6 leading-snug"
                    >
                        Contact Information
                    </h2>
                </div>

                {/* Contact detail cards */}
                <div
                    class="bg-gray-50 rounded-lg border border-gray-200 divide-y divide-gray-200"
                >
                    {
                        contactDetails.map((detail) => (
                            <div class="flex items-start gap-4 p-5">
                                <div class="w-10 h-10 rounded-md bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                    <Icon
                                        name={detail.icon}
                                        size="md"
                                        ariaLabel={detail.label}
                                    />
                                </div>
                                <div>
                                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 font-body mb-1">
                                        {detail.label}
                                    </p>
                                    {detail.isAddress ? (
                                        <address class="not-italic text-gray-700 font-body text-sm leading-relaxed">
                                            Lot S6-3, 2nd Floor,
                                            <br />
                                            Villa Tropicana Commercial,
                                            <br />
                                            Jalan Lintas, Penampang Bypass,
                                            <br />
                                            88300 Kota Kinabalu, Sabah
                                        </address>
                                    ) : detail.href ? (
                                        <a
                                            href={detail.href}
                                            class="text-gray-700 font-body text-sm font-medium hover:text-secondary transition-colors"
                                        >
                                            {detail.content}
                                        </a>
                                    ) : (
                                        <p class="text-gray-700 font-body text-sm leading-relaxed whitespace-pre-line">
                                            {detail.content}
                                        </p>
                                    )}
                                </div>
                            </div>
                        ))
                    }
                </div>

                {/* What to expect */}
                <div
                    class="bg-primary/5 rounded-lg border border-primary/10 p-6"
                >
                    <h3
                        class="font-display font-semibold text-base text-primary mb-4"
                    >
                        What to Expect
                    </h3>
                    <ul class="space-y-3">
                        {
                            expectations.map((item) => (
                                <li class="flex items-start gap-2.5 text-sm text-gray-700 font-body">
                                    <Icon
                                        name="check"
                                        size="sm"
                                        class="text-secondary shrink-0 mt-0.5"
                                    />
                                    <span>{item}</span>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                {/* Direct action buttons */}
                <div class="flex flex-col gap-3">
                    <a
                        href="tel:088742076"
                        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md font-semibold font-body text-sm bg-primary text-white hover:bg-primary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
                    >
                        <Icon name="phone" size="sm" ariaLabel="Call us" />
                        Call 088-742076
                    </a>
                    <a
                        href="mailto:jzlegalfirm@gmail.com"
                        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md font-semibold font-body text-sm bg-transparent border-2 border-primary text-primary hover:bg-primary/5 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
                    >
                        <Icon name="mail" size="sm" ariaLabel="Email us" />
                        jzlegalfirm@gmail.com
                    </a>
                </div>
            </div>
        </div>
    </SectionWrapper>

    {/* 3. Location Section */}
    <SectionWrapper id="location" class="bg-gray-50">
        <div class="text-center max-w-2xl mx-auto mb-10">
            <span
                class="text-secondary text-sm font-semibold uppercase tracking-widest font-body block mb-3"
            >
                Find Us
            </span>
            <h2
                class="text-3xl md:text-4xl font-display font-semibold text-primary mb-4"
            >
                Our Office Location
            </h2>
            <p class="text-gray-600 font-body text-base leading-relaxed">
                We are conveniently located along the Penampang Bypass in Kota
                Kinabalu, easily accessible from all parts of the city.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 items-start">
            {/* Map embed */}
            <div
                class="lg:col-span-2 rounded-lg overflow-hidden border border-gray-200 shadow-sm aspect-video"
            >
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3990.6843860897707!2d116.06897!3d5.94056!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x323b6781e0000001%3A0x0!2sVilla+Tropicana+Commercial%2C+Jalan+Lintas%2C+Penampang%2C+Kota+Kinabalu!5e0!3m2!1sen!2smy!4v1700000000000"
                    width="100%"
                    height="100%"
                    style="border:0;"
                    allowfullscreen
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    title="Jason Zulfadhli Advocates & Solicitors office location on Google Maps"
                    class="w-full h-full"></iframe>
            </div>

            {/* Directions card */}
            <div class="flex flex-col gap-4">
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <h3
                        class="font-display font-semibold text-base text-primary mb-4"
                    >
                        Getting Here
                    </h3>
                    <div class="space-y-4">
                        <div class="flex items-start gap-3">
                            <Icon
                                name="map-pin"
                                size="sm"
                                class="text-secondary shrink-0 mt-0.5"
                                ariaLabel="Address"
                            />
                            <address
                                class="not-italic text-gray-700 font-body text-sm leading-relaxed"
                            >
                                Lot S6-3, 2nd Floor,<br />
                                Villa Tropicana Commercial,<br />
                                Jalan Lintas, Penampang Bypass,<br />
                                88300 Kota Kinabalu, Sabah
                            </address>
                        </div>
                        <div class="border-t border-gray-100 pt-4 space-y-2.5">
                            <div
                                class="flex items-start gap-3 text-sm text-gray-600 font-body"
                            >
                                <Icon
                                    name="car"
                                    size="sm"
                                    class="text-secondary shrink-0 mt-0.5"
                                    ariaLabel="By car"
                                />
                                <span
                                    >Located along the Penampang Bypass (Jalan
                                    Lintas). Ample parking available at Villa
                                    Tropicana Commercial.</span
                                >
                            </div>
                            <div
                                class="flex items-start gap-3 text-sm text-gray-600 font-body"
                            >
                                <Icon
                                    name="clock"
                                    size="sm"
                                    class="text-secondary shrink-0 mt-0.5"
                                    ariaLabel="Office hours"
                                />
                                <span
                                    >Mon–Fri · 9:00 am – 1:00 pm, 2:00 pm – 5:00
                                    pm</span
                                >
                            </div>
                        </div>
                    </div>
                </div>

                <a
                    href="https://maps.google.com/?q=Villa+Tropicana+Commercial,+Jalan+Lintas,+Penampang,+Kota+Kinabalu,+Sabah"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md font-semibold font-body text-sm bg-secondary text-white hover:bg-secondary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary"
                >
                    <Icon
                        name="map-pin"
                        size="sm"
                        ariaLabel="Open in Google Maps"
                    />
                    Open in Google Maps
                </a>
            </div>
        </div>
    </SectionWrapper>
</BaseLayout>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const btnText = document.getElementById("btn-text");
    const btnSpinner = document.getElementById("btn-spinner");
    const formSuccess = document.getElementById("form-success");
    const formError = document.getElementById("form-error");

    const setFieldStatus = (
        input: HTMLInputElement | HTMLTextAreaElement,
        isValid: boolean,
    ) => {
        const errorSpan = document.getElementById(`${input.id}-error`);
        if (!isValid) {
            input.setAttribute("aria-invalid", "true");
            if (errorSpan) errorSpan.classList.remove("hidden");
        } else {
            input.removeAttribute("aria-invalid");
            if (errorSpan) errorSpan.classList.add("hidden");
        }
    };

    const validateForm = (): boolean => {
        let isValid = true;
        const inputs = form.querySelectorAll<
            HTMLInputElement | HTMLTextAreaElement
        >("input[required], textarea[required]");

        inputs.forEach((input) => {
            const valid = input.checkValidity();
            setFieldStatus(input, valid);
            if (!valid) isValid = false;
        });

        return isValid;
    };

    // Live validation on blur and input
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
        "input, textarea",
    ).forEach((input) => {
        input.addEventListener("blur", () =>
            setFieldStatus(input, input.checkValidity()),
        );
        input.addEventListener("input", () => {
            if (input.hasAttribute("aria-invalid")) {
                setFieldStatus(input, input.checkValidity());
            }
        });
    });

    form.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (formSuccess) formSuccess.classList.add("hidden");
        if (formError) formError.classList.add("hidden");

        if (!validateForm()) {
            const firstInvalid = form.querySelector(
                '[aria-invalid="true"]',
            ) as HTMLElement;
            if (firstInvalid) firstInvalid.focus();
            return;
        }

        submitBtn.disabled = true;
        if (btnText) btnText.classList.add("hidden");
        if (btnSpinner) btnSpinner.classList.remove("hidden");

        const formData = new FormData(form);

        try {
            const response = await fetch(form.action, {
                method: "POST",
                body: formData,
                headers: { Accept: "application/json" },
            });

            const result = await response.json();

            if (response.status === 200) {
                if (formSuccess) formSuccess.classList.remove("hidden");
                form.reset();
            } else {
                if (formError) formError.classList.remove("hidden");
                console.error("Form submission error:", result);
            }
        } catch (error) {
            if (formError) formError.classList.remove("hidden");
            console.error("Network error:", error);
        } finally {
            submitBtn.disabled = false;
            if (btnText) btnText.classList.remove("hidden");
            if (btnSpinner) btnSpinner.classList.add("hidden");
        }
    });
</script>
