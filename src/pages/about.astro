---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionWrapper from "../components/common/SectionWrapper.astro";
import PhilosophySection from "../components/sections/PhilosophySection.astro";
import CTABanner from "../components/sections/CTABanner.astro";
import TeamGrid from "../components/sections/TeamGrid.astro";
import Icon from "../components/common/Icon.astro";

const firmStats = [
    { label: "Established", value: "2021" },
    { label: "Practice Areas", value: "7" },
    { label: "Admitted Partners", value: "2" },
    { label: "Team Members", value: "7" },
];

const partners = [
    {
        name: "Jason Chin Wei Jye",
        role: "Founding Partner",
        tier: "partner" as const,
        admission: "Sabah Bar, 14th August 2020 (Admission No. 1392)",
        specialisations: [
            "Civil and Criminal Litigation",
            "Comprehensive legal solutions and strategic representation",
        ],
        qualifications: [
            "Certificate in Legal Practice (CLP)",
            "Bachelor of Laws (Hons), Oxford Brookes University, United Kingdom",
        ],
        profileHref: "/partners/jason-chin-wei-jye",
    },
    {
        name: "Mohd Zulfadhli Bin Darman Shah",
        role: "Managing Partner",
        tier: "partner" as const,
        admission: "Sabah Bar, 14th August 2020 (Admission No. 1381)",
        specialisations: [
            "Corporate matters and advisory",
            "Conveyancing and property transactions",
            "Appellate advocacy — Federal Court & Court of Appeal",
        ],
        qualifications: [
            "Foundation in Law, Multimedia University, Melaka",
            "Bachelor of Laws (Hons), Multimedia University, Melaka",
        ],
        profileHref: "/partners/mohd-zulfadhli-bin-darman-shah",
    },
];

const legalAssistants = [
    {
        name: "Beverly Ivy Lidadun",
        role: "Legal Assistant",
        tier: "legal-assistant" as const,
        admission: "Sabah Bar, 15th November 2023 (Admission No. 1547)",
        specialisations: [
            "Civil litigation and medical law",
            "Conveyancing matters",
            "Medical negligence and healthcare ethics",
        ],
        qualifications: [
            "Foundation in Law, UiTM Dengkil",
            "Bachelor of Laws (Honours), UiTM Shah Alam",
        ],
    },
    {
        name: "Magret Azeyra Rap",
        role: "Legal Assistant",
        tier: "legal-assistant" as const,
        admission:
            "High Court of Sabah & Sarawak, May 2024 (Admission No. 1582)",
        specialisations: [
            "Civil and criminal litigation",
            "Non-contentious matters",
            "Courtroom advocacy and case management",
        ],
        qualifications: ["Bachelor of Law (Hons), UiTM"],
    },
];

const supportStaff = [
    {
        name: "Alisha Siankie Pain",
        role: "Admin Clerk",
        tier: "support" as const,
        bio: "Manages schedules, coordinates appointments, files legal documents, drafts correspondence, handles client inquiries, and assists the conveyancing department with SPA and MOT preparation.",
        qualifications: [
            "Diploma in Public Administration, UiTM Kota Kinabalu",
            "Bachelor of Administrative Science (Hons.), UiTM Kota Kinabalu",
        ],
    },
    {
        name: "Josie Brynda Telado",
        role: "Conveyancing Clerk",
        tier: "support" as const,
        bio: "Drafts letters and client communications, prepares Sale and Purchase Agreements (SPA) and Memorandum of Transfer (MOT), arranges execution appointments, and monitors title transfer progress.",
        qualifications: ["Diploma in Accountancy, Polytechnic Kota Kinabalu"],
    },
    {
        name: "Syahiratul Nur Amalina binti Samlin",
        role: "Conveyancing Clerk",
        tier: "support" as const,
        bio: "Manages conveyancing matters professionally — experienced in sale and purchase agreements, loan documentation, and Syariah and civil proceedings.",
        qualifications: [
            "Diploma in Islamic Studies (Syariah and Law), UniPSAS",
            "Bachelor Degree in Syariah With Judicial Administration, UniPSAS",
        ],
    },
];
---

<BaseLayout
    title="About Us — Jason Zulfadhli Advocates & Solicitors"
    description="Learn about Jason Zulfadhli Advocates & Solicitors — our founding story, philosophy, partners, and the dedicated team behind our Kota Kinabalu law firm."
>
    {/* 1. Page Hero */}
    <section
        class="bg-primary py-20 md:py-28 relative overflow-hidden"
        aria-label="About page hero"
    >
        <div
            class="absolute top-0 right-0 w-80 h-80 bg-secondary/10 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"
            aria-hidden="true"
        >
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="flex items-center gap-2 mb-4">
                <a
                    href="/"
                    class="text-white/50 hover:text-white text-sm font-body transition-colors"
                    >Home</a
                >
                <Icon name="chevron-right" size="sm" class="text-white/30" />
                <span class="text-white/80 text-sm font-body">About</span>
            </div>
            <span
                class="text-saffron text-sm font-semibold uppercase tracking-widest font-body block mb-4"
            >
                Who We Are
            </span>
            <h1
                class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-white leading-tight max-w-3xl"
            >
                About Our Firm
            </h1>
            <p
                class="mt-6 text-lg font-body text-white/75 max-w-xl leading-relaxed"
            >
                Established in 2021, we are a dedicated team of legal
                professionals based in Penampang, Kota Kinabalu, committed to
                creative solutions and client-focused service.
            </p>
        </div>
    </section>

    {/* 2. Firm Story */}
    <SectionWrapper id="firm-story">
        <div
            class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start"
        >
            {/* Left — narrative */}
            <div>
                <span
                    class="text-secondary text-sm font-semibold uppercase tracking-widest font-body block mb-3"
                >
                    Our Story
                </span>
                <h2
                    class="text-3xl md:text-4xl font-display font-semibold text-primary mb-6 leading-snug"
                >
                    Built on Passion, Driven by Purpose
                </h2>
                <div
                    class="space-y-5 font-body text-gray-700 text-base leading-relaxed"
                >
                    <p>
                        <strong class="text-primary font-semibold"
                            >Jason Zulfadhli Advocates &amp; Solicitors</strong
                        >
                        was founded in <strong>2021</strong> by Mr. Jason Chin Wei
                        Jye, an Advocate &amp; Solicitor admitted to the Sabah Bar
                        on 14th August 2020. The firm began as <em
                            >JF &amp; Co.</em
                        > before being renamed following the arrival of Managing Partner
                        Mr. Mohd Zulfadhli Bin Darman Shah — a milestone that marked
                        the firm's evolution into a more comprehensive practice.
                    </p>
                    <p>
                        Located at <strong
                            >Villa Tropicana Commercial, Penampang</strong
                        >, the firm serves clients across Kota Kinabalu and the
                        wider state of Sabah. Our focus has always been clear:
                        to provide quality, professional legal service that is
                        responsive, honest, and effective.
                    </p>
                    <p>
                        We believe in bringing fresh perspectives and genuine
                        passion to every legal matter — whether it is a complex
                        civil dispute, a corporate transaction, or a family
                        property transfer. No case is too small; every client
                        deserves our full attention.
                    </p>
                </div>
            </div>

            {/* Right — stats grid */}
            <div>
                <div class="grid grid-cols-2 gap-4 mb-8">
                    {
                        firmStats.map((stat) => (
                            <div class="bg-gray-50 rounded-lg border border-gray-200 p-6 text-center">
                                <p class="text-3xl font-display font-bold text-primary mb-1">
                                    {stat.value}
                                </p>
                                <p class="text-sm text-gray-500 font-body">
                                    {stat.label}
                                </p>
                            </div>
                        ))
                    }
                </div>

                {/* Address card */}
                <div
                    class="bg-primary/5 rounded-lg border border-primary/10 p-6"
                >
                    <p
                        class="text-xs font-semibold uppercase tracking-wider text-gray-400 font-body mb-3"
                    >
                        Office Address
                    </p>
                    <div class="flex items-start gap-3">
                        <Icon
                            name="map-pin"
                            size="md"
                            class="text-secondary shrink-0 mt-0.5"
                            ariaLabel="Office location"
                        />
                        <address
                            class="not-italic text-gray-700 font-body text-sm leading-relaxed"
                        >
                            Lot S6-3, 2nd Floor, Villa Tropicana Commercial,<br
                            />
                            Jalan Lintas, Penampang Bypass,<br />
                            88300 Kota Kinabalu, Sabah
                        </address>
                    </div>
                    <div class="mt-4 pt-4 border-t border-primary/10 space-y-2">
                        <div
                            class="flex items-center gap-3 text-sm text-gray-600 font-body"
                        >
                            <Icon
                                name="clock"
                                size="sm"
                                class="text-secondary shrink-0"
                                ariaLabel="Operating hours"
                            />
                            <span
                                >Mon–Fri · 9:00 am – 1:00 pm, 2:00 pm – 5:00 pm</span
                            >
                        </div>
                        <div
                            class="flex items-center gap-3 text-sm text-gray-600 font-body"
                        >
                            <Icon
                                name="phone"
                                size="sm"
                                class="text-secondary shrink-0"
                                ariaLabel="Phone"
                            />
                            <a
                                href="tel:088742076"
                                class="hover:text-secondary transition-colors"
                                >088-742076</a
                            >
                        </div>
                        <div
                            class="flex items-center gap-3 text-sm text-gray-600 font-body"
                        >
                            <Icon
                                name="mail"
                                size="sm"
                                class="text-secondary shrink-0"
                                ariaLabel="Email"
                            />
                            <a
                                href="mailto:jzlegalfirm@gmail.com"
                                class="hover:text-secondary transition-colors"
                                >jzlegalfirm@gmail.com</a
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </SectionWrapper>

    {/* 3. Philosophy / Mission / Vision */}
    <PhilosophySection />

    {/* 4. Partners */}
    <SectionWrapper id="partners">
        <div class="text-center max-w-2xl mx-auto mb-12">
            <span
                class="text-secondary text-sm font-semibold uppercase tracking-widest font-body block mb-3"
            >
                Leadership
            </span>
            <h2
                class="text-3xl md:text-4xl font-display font-semibold text-primary mb-4"
            >
                Our Partners
            </h2>
            <p class="text-gray-600 font-body text-base leading-relaxed">
                The firm is led by two experienced advocates admitted to the
                Sabah Bar, bringing complementary expertise across litigation,
                corporate law, and conveyancing.
            </p>
        </div>
        <TeamGrid members={partners} gridClass="grid-cols-1 md:grid-cols-2" />
    </SectionWrapper>

    {/* 5. Legal Assistants */}
    <SectionWrapper id="legal-team" class="bg-gray-50">
        <div class="text-center max-w-2xl mx-auto mb-12">
            <span
                class="text-secondary text-sm font-semibold uppercase tracking-widest font-body block mb-3"
            >
                Our Team
            </span>
            <h2
                class="text-3xl md:text-4xl font-display font-semibold text-primary mb-4"
            >
                Legal Assistants
            </h2>
            <p class="text-gray-600 font-body text-base leading-relaxed">
                Our admitted legal assistants bring diverse experience and
                specialised knowledge to support our clients across a range of
                practice areas.
            </p>
        </div>
        <TeamGrid
            members={legalAssistants}
            gridClass="grid-cols-1 md:grid-cols-2"
        />

        {/* Support Staff */}
        <div class="mt-16">
            <div class="flex items-center gap-4 mb-8">
                <span class="block flex-1 h-px bg-gray-200"></span>
                <h3
                    class="text-xl font-display font-semibold text-primary whitespace-nowrap"
                >
                    Support Staff
                </h3>
                <span class="block flex-1 h-px bg-gray-200"></span>
            </div>
            <TeamGrid members={supportStaff} />
        </div>
    </SectionWrapper>

    {/* 6. CTA Banner */}
    <CTABanner
        heading="Have a Legal Matter We Can Help With?"
        subCopy="Our team in Kota Kinabalu is ready to assist. Reach out for a confidential consultation today."
        primaryLabel="Contact Us"
        primaryHref="/contact"
        secondaryLabel="Call the Office"
        secondaryHref="tel:088742076"
        phone="088-742076"
    />
</BaseLayout>
