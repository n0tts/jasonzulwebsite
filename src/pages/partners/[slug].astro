---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionWrapper from "../../components/common/SectionWrapper.astro";
import CTABanner from "../../components/sections/CTABanner.astro";
import Badge from "../../components/common/Badge.astro";
import Icon from "../../components/common/Icon.astro";
import { partners } from "../../data/partners";
import { Image } from "astro:assets";

export const getStaticPaths = (() => {
    return partners.map((partner) => ({
        params: { slug: partner.slug },
        props: { partner },
    }));
}) satisfies GetStaticPaths;

const { partner } = Astro.props;

// Previous / next partners for navigation
const currentIndex = partners.findIndex((p) => p.slug === partner.slug);
const prevPartner = partners[currentIndex - 1];
const nextPartner = partners[currentIndex + 1];
---

<BaseLayout
    title={`${partner.name} — ${partner.role} | Jason Zulfadhli Advocates & Solicitors`}
    description={`${partner.name} is the ${partner.role} of Jason Zulfadhli Advocates & Solicitors. Admitted to the ${partner.admissionBar} on ${partner.admissionDate}. Specialises in ${partner.specialisationHeading}.`}
>
    {/* Page Hero */}
    <section class="bg-primary py-20 md:py-28 relative overflow-hidden" aria-label="Partner profile hero">
        <div
            class="absolute top-0 right-0 w-96 h-96 bg-secondary/10 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"
            aria-hidden="true"
        ></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            {/* Breadcrumb */}
            <div class="flex items-center gap-2 mb-6 flex-wrap">
                <a href="/" class="text-white/50 hover:text-white text-sm font-body transition-colors">Home</a>
                <Icon name="chevron-right" size="sm" class="text-white/30" />
                <a href="/partners" class="text-white/50 hover:text-white text-sm font-body transition-colors">Partners</a>
                <Icon name="chevron-right" size="sm" class="text-white/30" />
                <span class="text-white/80 text-sm font-body">{partner.name}</span>
            </div>

            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
                <div>
                    <Badge variant="secondary" class="mb-4">{partner.role}</Badge>
                    <h1 class="text-4xl md:text-5xl font-display font-bold text-white leading-tight">
                        {partner.name}
                    </h1>
                    <div class="mt-4 flex items-center gap-2 text-white/70 font-body text-sm">
                        <Icon name="award" size="sm" class="text-saffron shrink-0" ariaLabel="Bar admission" />
                        <span>
                            Admitted to the {partner.admissionBar} on {partner.admissionDate}
                            &middot; Admission No. {partner.admissionNo}
                        </span>
                    </div>
                </div>

                {/* Back to all partners */}
                <a
                    href="/partners"
                    class="inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-body transition-colors shrink-0"
                >
                    <Icon name="arrow-left" size="sm" />
                    All Partners
                </a>
            </div>
        </div>
    </section>

    {/* Profile Body */}
    <SectionWrapper>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

            {/* Main content — left 2/3 */}
            <div class="lg:col-span-2 space-y-12">

                {/* Background */}
                <div>
                    <div class="flex items-center gap-3 mb-5">
                        <span class="block w-8 h-0.5 bg-secondary"></span>
                        <h2 class="text-xl font-display font-semibold text-primary uppercase tracking-wide">
                            Background
                        </h2>
                    </div>
                    <div class="space-y-4 font-body text-gray-700 text-base leading-relaxed">
                        {partner.bio.map((paragraph) => <p>{paragraph}</p>)}
                    </div>
                </div>

                {/* Area of Specialisation */}
                <div>
                    <div class="flex items-center gap-3 mb-5">
                        <span class="block w-8 h-0.5 bg-secondary"></span>
                        <h2 class="text-xl font-display font-semibold text-primary uppercase tracking-wide">
                            Area of Specialisation
                        </h2>
                    </div>
                    <h3 class="text-lg font-display font-semibold text-primary mb-4">
                        {partner.specialisationHeading}
                    </h3>
                    <div class="space-y-4 font-body text-gray-700 text-base leading-relaxed">
                        {partner.specialisationBody.map((paragraph) => <p>{paragraph}</p>)}
                    </div>
                </div>
            </div>

            {/* Sidebar — right 1/3 */}
            <aside class="space-y-6">

                {/* Partner photo */}
                <div class="rounded-lg overflow-hidden border border-gray-200 aspect-3/4">
                    <Image
                        src={partner.photo}
                        alt={`Photo of ${partner.name}`}
                        width={320}
                        height={427}
                        class="w-full h-full object-cover object-top"
                    />
                </div>

                {/* Qualifications card */}
                <div class="bg-gray-50 rounded-lg border border-gray-200 p-6">
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 font-body mb-4">
                        Qualifications
                    </p>
                    <ul class="space-y-3">
                        {
                            partner.qualifications.map((q) => (
                                <li class="flex items-start gap-2.5">
                                    <Icon
                                        name="graduation-cap"
                                        size="sm"
                                        class="text-secondary shrink-0 mt-0.5"
                                        ariaLabel=""
                                    />
                                    <span class="text-sm text-gray-700 font-body leading-snug">{q}</span>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                {/* Contact card */}
                <div class="bg-secondary/5 rounded-lg border border-secondary/20 p-6">
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 font-body mb-4">
                        Get in Touch
                    </p>
                    <a
                        href="/contact"
                        class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-secondary text-white text-sm font-semibold rounded-md hover:bg-secondary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary"
                    >
                        <Icon name="mail" size="sm" />
                        Send an Enquiry
                    </a>
                    <a
                        href="tel:088742076"
                        class="mt-3 flex items-center justify-center gap-2 w-full px-4 py-3 border-2 border-secondary text-secondary text-sm font-semibold rounded-md hover:bg-secondary/5 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary"
                    >
                        <Icon name="phone" size="sm" />
                        088-742076
                    </a>
                </div>
            </aside>
        </div>
    </SectionWrapper>

    {/* Prev / Next Partner Navigation */}
    {
        (prevPartner || nextPartner) && (
            <SectionWrapper class="bg-gray-50 py-10!">
                <div class="flex flex-col sm:flex-row justify-between gap-4">
                    {prevPartner ? (
                        <a
                            href={`/partners/${prevPartner.slug}`}
                            class="group flex items-center gap-3 text-left hover:text-secondary transition-colors focus:outline-none focus:ring-2 focus:ring-secondary rounded-md"
                        >
                            <Icon name="arrow-left" size="md" class="text-gray-400 group-hover:text-secondary transition-colors shrink-0" />
                            <div>
                                <p class="text-xs text-gray-400 uppercase tracking-wider font-body mb-0.5">Previous</p>
                                <p class="text-sm font-semibold text-primary group-hover:text-secondary transition-colors font-body">{prevPartner.name}</p>
                            </div>
                        </a>
                    ) : <div />}

                    {nextPartner && (
                        <a
                            href={`/partners/${nextPartner.slug}`}
                            class="group flex items-center gap-3 text-right justify-end hover:text-secondary transition-colors focus:outline-none focus:ring-2 focus:ring-secondary rounded-md"
                        >
                            <div>
                                <p class="text-xs text-gray-400 uppercase tracking-wider font-body mb-0.5">Next</p>
                                <p class="text-sm font-semibold text-primary group-hover:text-secondary transition-colors font-body">{nextPartner.name}</p>
                            </div>
                            <Icon name="arrow-right" size="md" class="text-gray-400 group-hover:text-secondary transition-colors shrink-0" />
                        </a>
                    )}
                </div>
            </SectionWrapper>
        )
    }

    <CTABanner
        heading="Ready to Solve Your Legal Problem?"
        subCopy="Contact Jason Zulfadhli Advocates & Solicitors for a confidential consultation with our team."
        primaryLabel="Contact Us"
        primaryHref="/contact"
        secondaryLabel="Call the Office"
        secondaryHref="tel:088742076"
        phone="088-742076"
    />
</BaseLayout>
