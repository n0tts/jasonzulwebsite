---
interface Props {
    variant?: "primary" | "secondary" | "outline" | "success" | "error";
    class?: string;
}

const { variant = "primary", class: className = "" } = Astro.props;

const baseStyles =
    "inline-flex items-center justify-center rounded-full px-2.5 py-0.5 text-xs font-semibold transition-colors";

const variants = {
    primary:
        "bg-primary/10 text-primary border border-transparent hover:bg-primary/20",
    secondary:
        "bg-secondary/10 text-secondary border border-transparent hover:bg-secondary/20",
    outline:
        "text-gray-700 border border-gray-300 bg-transparent hover:bg-gray-50",
    success: "bg-green-100 text-green-800 border border-transparent",
    error: "bg-red-100 text-red-800 border border-transparent",
};
---

<span class={`${baseStyles} ${variants[variant]} ${className}`}>
    <slot />
</span>
