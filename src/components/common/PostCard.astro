---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../../utils/helpers";
import { Image } from "astro:assets";

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, publishDate, tags, heroImage } = post.data;
---

<article
    class="bg-accent border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col h-full"
>
    {
        heroImage && (
            <a
                href={`/blog/${post.slug}`}
                class="block aspect-video overflow-hidden"
            >
                <Image
                    src={heroImage}
                    alt={title}
                    width={800}
                    height={450}
                    class="w-full h-full object-cover transition-transform hover:scale-105 duration-300"
                />
            </a>
        )
    }
    <div class="p-6 flex flex-col flex-grow">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
            <time
                datetime={publishDate.toISOString()}
                class="text-sm text-gray-500 font-medium"
            >
                {formatDate(publishDate)}
            </time>
            {tags.length > 0 && <span class="text-gray-300">&bull;</span>}
            <div class="flex flex-wrap gap-2">
                {
                    tags.map((tag: string) => (
                        <span class="inline-block bg-primary/10 text-primary rounded-full px-2 py-0.5 text-xs font-semibold">
                            {tag}
                        </span>
                    ))
                }
            </div>
        </div>
        <h3
            class="text-xl font-bold mb-3 font-serif text-primary leading-tight"
        >
            <a
                href={`/blog/${post.slug}`}
                class="hover:text-secondary transition-colors"
            >
                {title}
            </a>
        </h3>
        <p class="text-gray-600 mb-6 line-clamp-3 flex-grow">
            {description}
        </p>
        <a
            href={`/blog/${post.slug}`}
            class="text-secondary font-semibold hover:underline text-sm flex items-center gap-1 group mt-auto"
        >
            Read article
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
            >
                <path
                    fill-rule="evenodd"
                    d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
            </svg>
        </a>
    </div>
</article>
