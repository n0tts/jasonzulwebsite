---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string | URL;
  type?: "website" | "article";
  publishDate?: string;
  noindex?: boolean;
}

const siteUrl = Astro.site
  ? Astro.site.toString()
  : "https://jasonzulfadli.com";
const {
  title,
  description,
  image = "/og-default.png",
  canonicalURL = new URL(Astro.url.pathname, siteUrl).toString(),
  type = "website",
  publishDate,
  noindex = false,
} = Astro.props;

const siteName = "Jason Zulfadhli - Advocates & Solicitors";
const fullTitle =
  title === siteName || title.includes("Jason Zulfadhli")
    ? title
    : `${title} | ${siteName}`;

const imageURL = new URL(image, canonicalURL).toString();

const schema: any = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "Article" : "WebSite",
  name: siteName,
  url: canonicalURL,
  image: imageURL,
  description: description,
};

if (type === "article") {
  schema.headline = title;
  if (publishDate) {
    schema.datePublished = publishDate;
  }
}
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow" />
  )
}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
