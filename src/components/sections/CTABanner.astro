---
import Icon from "../common/Icon.astro";

interface Props {
    heading?: string;
    subCopy?: string;
    primaryLabel?: string;
    primaryHref?: string;
    secondaryLabel?: string;
    secondaryHref?: string;
    phone?: string;
}

const {
    heading = "Ready to Solve Your Legal Problem?",
    subCopy = "Our team is here to help. Reach out today for a confidential consultation with our experienced advocates.",
    primaryLabel = "Contact Us",
    primaryHref = "/contact",
    secondaryLabel = "Call Now",
    secondaryHref = "tel:+60147422775",
    phone = "088-742076",
} = Astro.props;
---

<section
    class="bg-secondary py-16 md:py-20"
    aria-label="Call to action"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
            {/* Text */}
            <div class="max-w-xl">
                <h2 class="text-2xl md:text-3xl font-display font-semibold text-white mb-3 leading-snug">
                    {heading}
                </h2>
                <p class="text-white/80 font-body text-base leading-relaxed mb-4">
                    {subCopy}
                </p>
                {
                    phone && (
                        <div class="flex items-center gap-2 text-white/90">
                            <Icon name="phone" size="sm" ariaLabel="Office phone" />
                            <a
                                href={`tel:${phone.replace(/[^+\d]/g, "")}`}
                                class="font-semibold font-body text-base hover:text-white transition-colors"
                            >
                                {phone}
                            </a>
                            <span class="text-white/50 text-sm">· Mon–Fri, 9am–5pm</span>
                        </div>
                    )
                }
            </div>

            {/* Buttons */}
            <div class="flex flex-col sm:flex-row gap-4 shrink-0">
                {
                    primaryHref && primaryLabel && (
                        <a
                            href={primaryHref}
                            class="inline-flex items-center justify-center px-8 py-3.5 font-semibold rounded-md transition-colors bg-white text-secondary hover:bg-white/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white focus:ring-offset-secondary"
                        >
                            {primaryLabel}
                            <Icon name="arrow-right" size="sm" class="ml-2" />
                        </a>
                    )
                }
                {
                    secondaryHref && secondaryLabel && (
                        <a
                            href={secondaryHref}
                            class="inline-flex items-center justify-center px-8 py-3.5 font-semibold rounded-md transition-colors bg-transparent border-2 border-white/60 text-white hover:bg-white/10 hover:border-white focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white focus:ring-offset-secondary"
                        >
                            <Icon name="phone" size="sm" class="mr-2" />
                            {secondaryLabel}
                        </a>
                    )
                }
            </div>
        </div>
    </div>
</section>
