---
import { Image } from "astro:assets";
import Button from "../common/Button.astro";
import Icon from "../common/Icon.astro";

interface Props {
    /** Main headline displayed in Playfair Display */
    headline: string;
    /** Optional secondary line in the headline (rendered in secondary colour) */
    headlineAccent?: string;
    /** Sub-copy paragraph beneath the headline */
    subCopy: string;
    /** Primary CTA label */
    primaryLabel?: string;
    /** Primary CTA href */
    primaryHref?: string;
    /** Secondary CTA label */
    secondaryLabel?: string;
    /** Secondary CTA href */
    secondaryHref?: string;
    /** Optional background image */
    bgImage?: ImageMetadata;
}

const {
    headline,
    headlineAccent,
    subCopy,
    primaryLabel = "Our Practice Areas",
    primaryHref = "/practice-areas",
    secondaryLabel = "Contact Us",
    secondaryHref = "/contact",
    bgImage,
} = Astro.props;
---

<section
    class="relative bg-primary overflow-hidden min-h-[600px] flex items-center"
    aria-label="Hero"
>
    {/* Background Image */}
    {
        bgImage && (
            <div class="absolute inset-0 z-0">
                <Image
                    src={bgImage}
                    alt=""
                    class="w-full h-full object-cover"
                    quality="high"
                    loading="eager"
                />
                {/* Dark Overlay for readability */}
                <div class="absolute inset-0 bg-primary/70 mix-blend-multiply" />
                <div class="absolute inset-0 bg-linear-to-r from-primary/90 via-primary/50 to-transparent" />
            </div>
        )
    }

    {
        /* Subtle decorative grid overlay - only show if no bgImage or as additional texture */
    }
    <div
        class="absolute inset-0 opacity-5 z-10"
        aria-hidden="true"
        style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 48px 48px;"
    >
    </div>

    {/* Decorative accent shape — top-right */}
    {
        !bgImage && (
            <div
                class="absolute top-0 right-0 w-72 h-72 md:w-96 md:h-96 bg-secondary/20 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl z-10"
                aria-hidden="true"
            />
        )
    }

    <div
        class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36 lg:py-44 w-full"
    >
        <div class="max-w-3xl">
            {/* Eyebrow */}
            <div class="flex items-center gap-2 mb-6">
                <span class="block w-8 h-0.5 bg-secondary"></span>
                <span
                    class="text-saffron text-sm font-semibold uppercase tracking-widest font-body"
                >
                    Advocates &amp; Solicitors · Kota Kinabalu, Sabah
                </span>
            </div>

            {/* Headline */}
            <h1
                class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-white leading-tight mb-6"
            >
                {headline}
                {
                    headlineAccent && (
                        <span class="block text-saffron mt-1">
                            {headlineAccent}
                        </span>
                    )
                }
            </h1>

            {/* Sub-copy */}
            <p
                class="text-lg md:text-xl font-body text-white/90 leading-relaxed mb-10 max-w-2xl"
            >
                {subCopy}
            </p>

            {/* CTAs */}
            <div class="flex flex-col sm:flex-row gap-4">
                {
                    primaryHref && primaryLabel && (
                        <a
                            href={primaryHref}
                            class="inline-flex items-center justify-center px-8 py-3.5 font-semibold rounded-md transition-colors bg-secondary text-white hover:bg-secondary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary focus:ring-offset-primary shadow-lg shadow-black/20"
                        >
                            {primaryLabel}
                            <Icon name="arrow-right" size="sm" class="ml-2" />
                        </a>
                    )
                }
                {
                    secondaryHref && secondaryLabel && (
                        <a
                            href={secondaryHref}
                            class="inline-flex items-center justify-center px-8 py-3.5 font-semibold rounded-md transition-colors bg-white/10 backdrop-blur-sm border-2 border-white/60 text-white hover:bg-white/20 hover:border-white focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white focus:ring-offset-primary"
                        >
                            <Icon name="phone" size="sm" class="mr-2" />
                            {secondaryLabel}
                        </a>
                    )
                }
            </div>
        </div>
    </div>
</section>
