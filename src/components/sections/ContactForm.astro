---
import Button from "../common/Button.astro";

// You will need to replace this with your actual Web3Forms access key
// Or load it from environment variables: import.meta.env.WEB3FORMS_ACCESS_KEY
const accessKey = "90a583fc-a5b1-4f8b-bb4d-e4753028551e";
---

<section class="w-full max-w-2xl mx-auto py-12 px-4 sm:px-6">
    <div class="mb-8 relative text-center">
        <h2 class="text-3xl font-bold font-serif text-primary mb-4">
            Get In Touch
        </h2>
        <p class="text-gray-600">
            Fill out the form below to request a consultation or ask a question.
        </p>
    </div>

    <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        class="space-y-6"
        novalidate
    >
        <input type="hidden" name="access_key" value={accessKey} />
        {/* Honeypot Spam Protection */}
        <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display: none;"
        />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="flex flex-col">
                <label
                    for="name"
                    class="text-sm font-semibold text-gray-700 mb-1"
                    >Full Name <span class="text-red-500">*</span></label
                >
                <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    autocomplete="name"
                    aria-describedby="name-error"
                    class="w-full rounded border border-gray-300 px-4 py-2 text-gray-900 focus:border-secondary focus:ring-secondary aria-[invalid=true]:border-red-500 aria-[invalid=true]:ring-red-500 transition-colors"
                />
                <span
                    id="name-error"
                    class="text-red-500 text-sm mt-1 hidden font-medium"
                    aria-live="polite">Please enter your full name.</span
                >
            </div>

            <div class="flex flex-col">
                <label
                    for="phone"
                    class="text-sm font-semibold text-gray-700 mb-1"
                    >Phone Number <span class="text-red-500">*</span></label
                >
                <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    autocomplete="tel"
                    aria-describedby="phone-error"
                    class="w-full rounded border border-gray-300 px-4 py-2 text-gray-900 focus:border-secondary focus:ring-secondary aria-[invalid=true]:border-red-500 aria-[invalid=true]:ring-red-500 transition-colors"
                />
                <span
                    id="phone-error"
                    class="text-red-500 text-sm mt-1 hidden font-medium"
                    aria-live="polite">Please enter a valid phone number.</span
                >
            </div>
        </div>

        <div class="flex flex-col">
            <label for="email" class="text-sm font-semibold text-gray-700 mb-1"
                >Email Address <span class="text-red-500">*</span></label
            >
            <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                aria-describedby="email-error"
                class="w-full rounded border border-gray-300 px-4 py-2 text-gray-900 focus:border-secondary focus:ring-secondary aria-[invalid=true]:border-red-500 aria-[invalid=true]:ring-red-500 transition-colors"
            />
            <span
                id="email-error"
                class="text-red-500 text-sm mt-1 hidden font-medium"
                aria-live="polite">Please enter a valid email address.</span
            >
        </div>

        <div class="flex flex-col">
            <label
                for="subject"
                class="text-sm font-semibold text-gray-700 mb-1"
                >Subject (Optional)</label
            >
            <input
                type="text"
                id="subject"
                name="subject"
                class="w-full rounded border border-gray-300 px-4 py-2 text-gray-900 focus:border-secondary focus:ring-secondary transition-colors"
            />
        </div>

        <div class="flex flex-col">
            <label
                for="message"
                class="text-sm font-semibold text-gray-700 mb-1"
                >Message <span class="text-red-500">*</span></label
            >
            <textarea
                id="message"
                name="message"
                rows="5"
                required
                aria-describedby="message-error"
                class="w-full rounded border border-gray-300 px-4 py-2 text-gray-900 focus:border-secondary focus:ring-secondary aria-[invalid=true]:border-red-500 aria-[invalid=true]:ring-red-500 transition-colors resize-y"
            ></textarea>
            <span
                id="message-error"
                class="text-red-500 text-sm mt-1 hidden font-medium"
                aria-live="polite">Please enter a message.</span
            >
        </div>

        <div class="pt-2">
            <Button type="submit" class="w-full sm:w-auto px-8" id="submit-btn">
                <span id="btn-text">Send Message</span>
                <svg
                    id="btn-spinner"
                    class="animate-spin ml-2 h-5 w-5 text-white hidden"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                >
                    <circle
                        class="opacity-25"
                        cx="12"
                        cy="12"
                        r="10"
                        stroke="currentColor"
                        stroke-width="4"></circle>
                    <path
                        class="opacity-75"
                        fill="currentColor"
                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                    ></path>
                </svg>
            </Button>
        </div>

        {/* Status Messages */}
        <div
            id="form-success"
            class="hidden rounded-md bg-green-50 p-4 mt-4 border border-green-200"
            aria-live="polite"
        >
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg
                        class="h-5 w-5 text-green-400"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-green-800">
                        Message sent successfully! We will get back to you soon.
                    </p>
                </div>
            </div>
        </div>

        <div
            id="form-error"
            class="hidden rounded-md bg-red-50 p-4 mt-4 border border-red-200"
            aria-live="polite"
        >
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg
                        class="h-5 w-5 text-red-400"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-red-800">
                        Oops! Something went wrong. Please try again later.
                    </p>
                </div>
            </div>
        </div>
    </form>
</section>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const btnText = document.getElementById("btn-text");
    const btnSpinner = document.getElementById("btn-spinner");
    const formSuccess = document.getElementById("form-success");
    const formError = document.getElementById("form-error");

    const setFieldStatus = (
        input: HTMLInputElement | HTMLTextAreaElement,
        isValid: boolean,
    ) => {
        const errorSpan = document.getElementById(`${input.id}-error`);
        if (!isValid) {
            input.setAttribute("aria-invalid", "true");
            if (errorSpan) errorSpan.classList.remove("hidden");
        } else {
            input.removeAttribute("aria-invalid");
            if (errorSpan) errorSpan.classList.add("hidden");
        }
    };

    const validateForm = (): boolean => {
        let isValid = true;
        const inputs = form.querySelectorAll<
            HTMLInputElement | HTMLTextAreaElement
        >("input[required], textarea[required]");

        inputs.forEach((input) => {
            // Use Constraint Validation API
            const valid = input.checkValidity();
            setFieldStatus(input, valid);
            if (!valid) isValid = false;
        });

        return isValid;
    };

    // Live validation on blur & input
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
        "input, textarea",
    ).forEach((input) => {
        input.addEventListener("blur", () =>
            setFieldStatus(input, input.checkValidity()),
        );
        input.addEventListener("input", () => {
            if (input.hasAttribute("aria-invalid")) {
                setFieldStatus(input, input.checkValidity());
            }
        });
    });

    form.addEventListener("submit", async (e) => {
        e.preventDefault();

        // Hide previous messages
        if (formSuccess) formSuccess.classList.add("hidden");
        if (formError) formError.classList.add("hidden");

        if (!validateForm()) {
            // Focus first invalid field for accessibility
            const firstInvalid = form.querySelector(
                '[aria-invalid="true"]',
            ) as HTMLElement;
            if (firstInvalid) firstInvalid.focus();
            return;
        }

        // Set loading state
        submitBtn.disabled = true;
        if (btnText) btnText.classList.add("hidden");
        if (btnSpinner) btnSpinner.classList.remove("hidden");

        const formData = new FormData(form);

        try {
            const response = await fetch(form.action, {
                method: "POST",
                body: formData,
                headers: {
                    Accept: "application/json",
                },
            });

            const result = await response.json();

            if (response.status === 200) {
                if (formSuccess) formSuccess.classList.remove("hidden");
                form.reset();
            } else {
                if (formError) formError.classList.remove("hidden");
                console.error("Form error:", result);
            }
        } catch (error) {
            if (formError) formError.classList.remove("hidden");
            console.error("Network error:", error);
        } finally {
            // Revert loading state
            submitBtn.disabled = false;
            if (btnText) btnText.classList.remove("hidden");
            if (btnSpinner) btnSpinner.classList.add("hidden");
        }
    });
</script>
