---
import { Image } from "astro:assets";
import { siteConfig, type NavLink } from "../../config/site";
import logoSrc from "../../assets/jasonzulfadhli-logo.png";

interface Props {
    logoText?: string;
}

const { logoText = siteConfig.name } = Astro.props;

const currentPath = Astro.url.pathname;

const isActive = (link: NavLink): boolean => {
    if (link.href === "/") return currentPath === "/";
    if (currentPath.startsWith(link.href)) return true;
    return link.children?.some((c) => currentPath.startsWith(c.href)) ?? false;
};
---

<header
    class="sticky top-0 z-50 w-full bg-primary border-b border-primary/30 shadow-md transition-all duration-300"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
            {/* Skip to content */}
            <a
                href="#main-content"
                class="absolute left-4 top-4 -translate-y-24 focus:translate-y-0 bg-secondary text-white px-4 py-2 rounded-md font-semibold z-50 transition-transform focus:outline-none"
            >
                Skip to main content
            </a>

            {/* Logo */}
            <div class="shrink-0 flex items-center">
                <a
                    href="/"
                    class="focus:outline-none focus:ring-2 focus:ring-secondary rounded-sm"
                    aria-label={`${logoText} — Home`}
                >
                    <Image
                        src={logoSrc}
                        alt={logoText}
                        height={80}
                        loading="eager"
                        fetchpriority="high"
                        class="h-[80px] w-auto"
                    />
                </a>
            </div>

            {/* Desktop Navigation */}
            <nav class="hidden md:flex items-center space-x-1" aria-label="Main Navigation">
                {
                    siteConfig.navLinks.map((link) =>
                        link.children ? (
                            /* Dropdown item */
                            <div class="relative group/dd">
                                <a
                                    href={link.href}
                                    class={`inline-flex items-center gap-1 px-3 py-2 text-sm font-semibold rounded-md border-b-2 transition-colors focus:outline-none focus:ring-2 focus:ring-secondary ${
                                        isActive(link)
                                            ? "border-saffron text-saffron"
                                            : "border-transparent text-white/75 hover:text-white hover:border-white/40"
                                    }`}
                                    aria-haspopup="true"
                                    aria-current={isActive(link) ? "page" : undefined}
                                >
                                    {link.label}
                                    {/* Chevron */}
                                    <svg
                                        class="w-3.5 h-3.5 shrink-0 transition-transform duration-200 group-hover/dd:rotate-180"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2.5"
                                        aria-hidden="true"
                                    >
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </a>

                                {/* Dropdown panel */}
                                <div class="absolute top-full left-0 z-50 invisible opacity-0 group-hover/dd:visible group-hover/dd:opacity-100 transition-all duration-150 translate-y-1 group-hover/dd:translate-y-0">
                                    <div class="mt-1 w-64 bg-white rounded-md shadow-xl border border-gray-100 py-1 overflow-hidden">
                                        {link.children.map((child) => (
                                            <a
                                                href={child.href}
                                                class={`flex items-center px-4 py-2.5 text-sm font-medium transition-colors ${
                                                    currentPath === child.href
                                                        ? "bg-primary/5 text-secondary"
                                                        : "text-gray-700 hover:bg-gray-50 hover:text-primary"
                                                }`}
                                                aria-current={currentPath === child.href ? "page" : undefined}
                                            >
                                                {child.label}
                                            </a>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ) : (
                            /* Regular link */
                            <a
                                href={link.href}
                                class={`inline-flex items-center px-3 py-2 text-sm font-semibold rounded-md border-b-2 transition-colors focus:outline-none focus:ring-2 focus:ring-secondary ${
                                    isActive(link)
                                        ? "border-saffron text-saffron"
                                        : "border-transparent text-white/75 hover:text-white hover:border-white/40"
                                }`}
                                aria-current={isActive(link) ? "page" : undefined}
                            >
                                {link.label}
                            </a>
                        )
                    )
                }
            </nav>

            {/* Mobile Menu Button */}
            <div class="flex items-center md:hidden">
                <button
                    type="button"
                    id="mobile-menu-button"
                    class="inline-flex items-center justify-center p-2 rounded-md text-white/75 hover:text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-secondary transition-colors"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                >
                    <span class="sr-only">Open main menu</span>
                    <svg id="menu-icon-open" class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <svg id="menu-icon-close" class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    {/* Mobile Menu Panel */}
    <div class="md:hidden hidden bg-primary border-b border-primary/30" id="mobile-menu">
        <div class="px-2 pt-2 pb-3 space-y-0.5 sm:px-3">
            {
                siteConfig.navLinks.map((link) => (
                    <>
                        <a
                            href={link.href}
                            class={`flex items-center justify-between px-3 py-2.5 rounded-md text-base font-medium transition-colors ${
                                isActive(link)
                                    ? "bg-white/10 text-saffron"
                                    : "text-white/75 hover:bg-white/10 hover:text-white"
                            }`}
                            aria-current={isActive(link) ? "page" : undefined}
                        >
                            {link.label}
                        </a>
                        {link.children && (
                            <div class="pl-4 space-y-0.5 border-l border-white/10 ml-3">
                                {link.children.map((child) => (
                                    <a
                                        href={child.href}
                                        class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${
                                            currentPath === child.href
                                                ? "text-saffron"
                                                : "text-white/60 hover:text-white hover:bg-white/10"
                                        }`}
                                        aria-current={currentPath === child.href ? "page" : undefined}
                                    >
                                        {child.label}
                                    </a>
                                ))}
                            </div>
                        )}
                    </>
                ))
            }
        </div>
    </div>
</header>

<script>
    const btn = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("menu-icon-open");
    const iconClose = document.getElementById("menu-icon-close");

    if (btn && menu && iconOpen && iconClose) {
        btn.addEventListener("click", () => {
            const expanded = btn.getAttribute("aria-expanded") === "true";
            btn.setAttribute("aria-expanded", (!expanded).toString());
            menu.classList.toggle("hidden");
            iconOpen.classList.toggle("hidden");
            iconClose.classList.toggle("hidden");
            iconOpen.classList.toggle("block");
            iconClose.classList.toggle("block");
        });
    }
</script>
