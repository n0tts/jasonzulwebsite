---
import { Image } from "astro:assets";
import { siteConfig } from "../../config/site";
import logoSrc from "../../assets/jasonzulfadhli-logo.png";

const currentYear = new Date().getFullYear();

const quickLinks = siteConfig.navLinks.filter((l) => l.href !== "/");
---

<footer class="bg-primary border-t border-white/10" aria-label="Site footer">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {/* Main footer body */}
        <div
            class="py-12 md:py-16 flex flex-col items-center text-center gap-8"
        >
            {/* Logo */}
            <a
                href="/"
                class="inline-block focus:outline-none focus:ring-2 focus:ring-secondary rounded-sm"
                aria-label={`${siteConfig.name} — Home`}
            >
                <Image
                    src={logoSrc}
                    alt={siteConfig.name}
                    height={72}
                    loading="lazy"
                    class="h-[72px] w-auto"
                />
            </a>

            {/* Firm name + tagline */}
            <div class="flex flex-col gap-2">
                <p
                    class="font-display font-semibold text-white text-lg leading-snug"
                >
                    Jason Zulfadhli Advocates &amp; Solicitors
                </p>
                <p
                    class="font-body text-white/60 text-sm leading-relaxed max-w-sm"
                >
                    Creative legal solutions for individuals, families, and
                    businesses in Kota Kinabalu, Sabah. Established 2021.
                </p>
            </div>

            {/* Divider */}
            <div class="w-16 border-t border-white/20" aria-hidden="true"></div>

            {/* Quick links */}
            <nav aria-label="Footer navigation">
                <p
                    class="text-xs font-semibold uppercase tracking-widest text-white/40 font-body mb-4"
                >
                    Quick Links
                </p>
                <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2">
                    <li>
                        <a
                            href="/"
                            class="text-sm font-body text-white/60 hover:text-white transition-colors"
                        >
                            Home
                        </a>
                    </li>
                    {
                        quickLinks.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-sm font-body text-white/60 hover:text-white transition-colors"
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>
        </div>

        {/* Bottom bar — copyright, legal links */}
        <div
            class="border-t border-white/10 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs font-body text-white/40"
        >
            <p>
                &copy; {currentYear} Jason Zulfadhli Advocates &amp; Solicitors. All
                rights reserved.
            </p>
            <div class="flex items-center gap-4">
                <a
                    href="/privacy-policy"
                    class="hover:text-white/70 transition-colors"
                >
                    Privacy Policy
                </a>
                <span class="text-white/20" aria-hidden="true">·</span>
                <a
                    href="/disclaimer"
                    class="hover:text-white/70 transition-colors"
                >
                    Disclaimer
                </a>
            </div>
        </div>
    </div>
</footer>
