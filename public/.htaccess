# ============================================================
# Astro Static Site — Apache / cPanel Configuration
# ============================================================

# ── Rewrite Engine ──────────────────────────────────────────
RewriteEngine On

# ── Clean URLs (serve /about → /about/index.html) ───────────
# Skip if the request is for an existing file or directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Try the path as a directory with index.html
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/index.html -f
RewriteRule ^(.+)$ /$1/index.html [L]

# ── Custom 404 ───────────────────────────────────────────────
ErrorDocument 404 /404/index.html

# ── Trailing Slash Removal ───────────────────────────────────
# Remove trailing slashes from non-directory URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# ── HTTPS Redirect ───────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── WWW → Non-WWW ────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ── Browser Caching ─────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2  "access plus 1 year"
  ExpiresByType font/woff   "access plus 1 year"
  ExpiresByType text/css    "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# ── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Gzip Compression ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# ── Block Sensitive Files ────────────────────────────────────
<FilesMatch "(^\.htaccess|\.env|package\.json|package-lock\.json)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>
